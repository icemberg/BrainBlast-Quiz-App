# Spring Boot Production Database Configuration
DB_URL=jdbc:mysql://production-db-host:3306/quizapplication
DB_USERNAME=root
DB_PASSWORD=your_production_password

# Spring Boot Production Redis Configuration
REDIS_HOST=production-redis-host
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# Spring Boot Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# React Production Configuration
VITE_API_URL=https://api.yourproductiondomain.com
